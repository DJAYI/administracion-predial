# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=geopix
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DB_PORT=5433

# ── JWT ───────────────────────────────────────────────────────────────────────
# IMPORTANT: Generate a strong secret for production (min 32 chars)
#   openssl rand -base64 48
JWT_SECRET_KEY=cH4ng3Th1sS3cr3tK3yInPr0duct10n!AtL3ast256B1ts
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── Cookies ───────────────────────────────────────────────────────────────────
# Set to true when serving over HTTPS in production
COOKIE_SECURE=false
# Lax is correct when using the reverse proxy (same-origin)
# Use Strict for maximum security in production with HTTPS
COOKIE_SAME_SITE=Lax

# ── Reverse Proxy ─────────────────────────────────────────────────────────────
# Port where nginx serves the unified app (frontend + API)
PROXY_PORT=80
